// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  password      String?
  role          String    @default("CLIENT") // "CLIENT" | "ADMIN"
  restaurant    String?
  phone         String?
  createdAt     DateTime  @default(now())
  accounts      Account[]
  sessions      Session[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Proposal {
  id             String   @id @default(cuid())
  slug           String   @unique
  clientName     String
  restaurantName String?
  email          String?
  phone          String?
  services       String   // JSON string of selected services
  total          Float
  validity       Int      // Days
  contractMonths Int
  observations   String?
  createdAt      DateTime @default(now())
}
model Lead {
  id           String   @id @default(cuid())
  nome         String
  endereco     String?
  bairro       String?
  telefone     String?
  instagram    String?
  rating       Float?
  totalReviews Int?
  status       String   @default("capturados") // "capturados" | "qualificados" | "abordados" | "respondeu" | "reuniao" | "ganho" | "perdido"
  nicho        String?
  cidade       String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
